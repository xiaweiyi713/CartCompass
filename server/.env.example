# Do not commit the shared challenge key. Put your own/local key here.
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=ep-20260514111645-lmgt2

# Optional model gateway defaults. Runtime BYOK configs are normally set through
# /api/llm/config and kept in server memory only.
LLM_DEFAULT_PROVIDER=ark
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_DEFAULT_TIMEOUT_SECONDS=8

# Optional real text embedding retrieval. If unset, retrieval automatically
# falls back to local hashing vectors.
TEXT_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
TEXT_EMBEDDING_MODEL=
TEXT_EMBEDDING_API_KEY=
TEXT_EMBEDDING_TIMEOUT_SECONDS=8

# Optional OpenAI-compatible vision model. If unset, image search still works
# with CLIP/lightweight visual features.
VISION_UNDERSTANDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VISION_UNDERSTANDING_MODEL=doubao-seed-2-0-lite-260428
VISION_UNDERSTANDING_API_KEY=
VISION_UNDERSTANDING_TIMEOUT_SECONDS=12
VISION_UNDERSTANDING_IMAGE_DETAIL=auto
VISION_UNDERSTANDING_MAX_IMAGE_SIDE=1024
VISION_UNDERSTANDING_MAX_TOKENS=300
VISION_UNDERSTANDING_JSON_MODE=false

SHOPGUIDE_DB=server/storage/shopguide.sqlite3
SHOPGUIDE_STATIC_DIR=server/static
